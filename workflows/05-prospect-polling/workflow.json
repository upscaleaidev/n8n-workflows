        "additionalFields": {
          "appendAttribution": false,
          "parse_mode": "HTML",
          "replyMarkup": "inlineKeyboard",
          "replyMarkupUi": {
            "values": [
              {
                "row": [
                  {
                    "text": "✅ Envoyer",
                    "callbackData": "send_{{ $json.message_id }}"
                  },
                  {
                    "text": "❌ Ignorer",
                    "callbackData": "skip_{{ $json.message_id }}"
                  }
                ]
              }
            ]
          }
        }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
